    db.close()
    return render_template('blog.html', articles=articles)

@app.route('/blog/<int:article_id>')
def blog_detail(article_id):
    db = get_db()
    cursor = db.cursor()
    cursor.execute("SELECT * FROM coffee_news WHERE id = %s AND is_active = 1", (article_id,))
    article = cursor.fetchone()
    db.close()
    if not article:
        flash('Article not found', 'danger')
        return redirect(url_for('blog'))
    return render_template('blog_detail.html', article=article)

def translate_article(title, content, target_lang):
    """Automatically translate article title and content to target language"""
    try:
        # Map language codes for Google Translate
        lang_map = {
            'fi': 'fi',  # Finnish
            'sv': 'sv',  # Swedish
            'fa': 'fa'   # Persian
        }
        
        if target_lang not in lang_map:
            return title, content
        
        translator = GoogleTranslator(source='en', target=lang_map[target_lang])
        
        translated_title = translator.translate(title)
        translated_content = translator.translate(content)
        
        return translated_title, translated_content
    except Exception as e:
        print(f"Translation error for {target_lang}: {e}")
        return title, content

