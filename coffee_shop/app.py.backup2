@app.route('/api/delete-order/<int:order_id>', methods=['POST'])
@login_required
def delete_order(order_id):
    db = get_db()
    cursor = db.cursor()
    cursor.execute("DELETE FROM order_items WHERE order_id = %s", (order_id,))
    cursor.execute("DELETE FROM orders WHERE id = %s AND user_id = %s", (order_id, current_user.id))
    db.commit()
    db.close()
    return jsonify({'success': True, 'message': 'Order deleted successfully'})

@app.route('/api/track-order/<order_number>')
def api_track_order(order_number):
    """API endpoint to get order details for tracking"""
    db = get_db()
    cursor = db.cursor()
    
    # First try regular orders table (web orders)
    cursor.execute("""
        SELECT order_number, total_amount, status, created_at 
        FROM orders 
        WHERE order_number = %s
    """, (order_number,))
    order = cursor.fetchone()
    
    # If not found, try chatbot_orders table
    if not order:
        cursor.execute("""
            SELECT order_number, total_amount, status, created_at 
            FROM chatbot_orders 
            WHERE order_number = %s
        """, (order_number,))
        order = cursor.fetchone()
    
    db.close()
    
    if order:
        return jsonify({
            'order_number': order['order_number'],
            'total_amount': float(order['total_amount']),
            'status': order['status'],
            'created_at': order['created_at'].isoformat() if order['created_at'] else None
        })
    else:
        return jsonify({'error': 'Order not found'}), 404

    if request.method == 'POST':
        full_name = request.form.get('full_name')
        email = request.form.get('email')

        if not full_name or not email:
            flash(t('newsletter_error'), 'danger')
            return redirect(url_for('newsletter'))

        try:
            db = get_db()
            cursor = db.cursor()

            # Check if email already exists
            cursor.execute("SELECT * FROM newsletter_subscribers WHERE email = %s", (email,))
            existing = cursor.fetchone()

            if existing:
                flash(t('newsletter_already_subscribed'), 'warning')
            else:
                cursor.execute(
                    "INSERT INTO newsletter_subscribers (full_name, email, subscribed_at) VALUES (%s, %s, NOW())",
                    (full_name, email)
                )
                db.commit()
                flash(t('newsletter_success'), 'success')

            db.close()
        except Exception as e:
            flash(t('newsletter_error'), 'danger')

        return redirect(url_for('newsletter'))

    return render_template('newsletter.html')

