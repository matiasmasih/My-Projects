@app.route('/newsletter', methods=['GET', 'POST'])
def newsletter():
    if request.method == 'POST':
        full_name = request.form.get('full_name')
        email = request.form.get('email')
        
        if not full_name or not email:
            flash(t('newsletter_error'), 'danger')
            return redirect(url_for('newsletter'))
        
        try:
            db = get_db()
            cursor = db.cursor()
            
            cursor.execute("SELECT * FROM newsletter_subscribers WHERE email = %s", (email,))
            existing = cursor.fetchone()
            
            if existing:
                flash(t('newsletter_already_subscribed'), 'warning')
            else:
                token = str(uuid.uuid4())
                cursor.execute(
                    "INSERT INTO newsletter_subscribers (full_name, email, confirmation_token, is_confirmed, subscribed_at) VALUES (%s, %s, %s, 0, NOW())",
                    (full_name, email, token)
                )
                db.commit()
                send_newsletter_confirmation(email, full_name, token)
                flash(t('newsletter_check_email'), 'success')
            
            db.close()
        except Exception as e:
            print(f"Error: {e}")
            flash(t('newsletter_error'), 'danger')
        
        return redirect(url_for('newsletter'))
    
    db = get_db()
    cursor = db.cursor()
    cursor.execute("SELECT id, title, category, content, image_url, author, published_at FROM coffee_news WHERE is_active = 1 ORDER BY published_at DESC LIMIT 4")
    news_list = cursor.fetchall()
    db.close()
    
    if not news_list:
        news_list = [
            {'id': 1, 'title': 'Exclusive Offers', 'category': 'offers', 'icon': 'fa-tag', 'short_description': 'Get special discounts and promotions only for subscribers'},
            {'id': 2, 'title': 'Free Coffee', 'category': 'giveaway', 'icon': 'fa-gift', 'short_description': 'Win free coffee every month in our subscriber giveaways'},
            {'id': 3, 'title': 'Early Access', 'category': 'early-access', 'icon': 'fa-clock', 'short_description': 'Be the first to know about new coffee blends'},
            {'id': 4, 'title': 'Brewing Tips', 'category': 'tips', 'icon': 'fa-book', 'short_description': 'Learn professional brewing techniques at home'}
        ]
    else:
        for news in news_list:
            if 'offer' in news['category'].lower():
                news['icon'] = 'fa-tag'
            elif 'giveaway' in news['category'].lower():
                news['icon'] = 'fa-gift'
            elif 'early' in news['category'].lower():
                news['icon'] = 'fa-clock'
            else:
                news['icon'] = 'fa-book'
            news['short_description'] = news['content'][:120] + '...'
    
    return render_template('newsletter.html', news_list=news_list)

@app.route('/news/<int:news_id>')
def news_detail(news_id):
    db = get_db()
    cursor = db.cursor()
    cursor.execute("SELECT * FROM coffee_news WHERE id = %s", (news_id,))
    news = cursor.fetchone()
    db.close()

    if not news:
        flash('Article not found', 'danger')
        return redirect(url_for('newsletter'))

    return render_template('news_detail.html', news=news)


@app.route('/news')
def news_page():
    db = get_db()
    cursor = db.cursor()
    cursor.execute("SELECT * FROM coffee_news WHERE is_active = 1 ORDER BY published_at DESC")
    all_news = cursor.fetchall()
    db.close()

    featured = all_news[0] if all_news else None
    articles = all_news[1:5] if all_news else []

    return render_template('news_page.html', featured=featured, articles=articles)

