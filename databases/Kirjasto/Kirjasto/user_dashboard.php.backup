<?php
// Start session and include database connection
error_reporting(E_ALL);
ini_set('display_errors', 1);
session_start();
require_once 'connection.php';

// Check if user is logged in
if (!isset($_SESSION['user_id'])) {
    header("Location: login.php");
    exit();
}

$user_id = $_SESSION['user_id'];

// Get user information
$user_query = "SELECT * FROM jasenet WHERE id = ?";
$stmt = $conn->prepare($user_query);
$stmt->bind_param("i", $user_id);
$stmt->execute();
$result = $stmt->get_result();
$user = $result->fetch_assoc();

if (!$user) {
    session_destroy();
    header("Location: login.php");
    exit();
}

// Create membership number if not exists
$membership_number = isset($user['jasennumero']) && !empty($user['jasennumero'])
    ? $user['jasennumero']
    : 'JASEN-' . str_pad($user['id'], 6, '0', STR_PAD_LEFT);

// Initialize variables with default values
$available_books_count = 0;
$active_loans_count = 0;
$loan_history_count = 0;
$fines_total = 0;
$available_devices_count = 0;
$active_device_loans_count = 0;
$reservations_count = 0;
$overdue_loans_count = 0;

// Get available books count (from Kirjakopiot)
try {
    $available_books_query = "SELECT COUNT(*) as count FROM Kirjakopiot WHERE tila = 'saatavilla'";
    $available_books_result = $conn->query($available_books_query);
    if ($available_books_result) {
        $available_books = $available_books_result->fetch_assoc();
        $available_books_count = $available_books['count'];
    }
} catch (Exception $e) {
    error_log("Books count error: " . $e->getMessage());
}

// Get user's active loans count
try {
    $active_loans_query = "SELECT COUNT(*) as count FROM lainat WHERE jasen_id = ? AND tila = 'aktiivinen'";
    $stmt = $conn->prepare($active_loans_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $active_loans_result = $stmt->get_result();
    $active_loans = $active_loans_result->fetch_assoc();
    $active_loans_count = $active_loans['count'];
} catch (Exception $e) {
    error_log("Active loans error: " . $e->getMessage());
}

// Get user's overdue loans count
try {
    $overdue_query = "SELECT COUNT(*) as count FROM lainat WHERE jasen_id = ? AND tila = 'myohassa'";
    $stmt = $conn->prepare($overdue_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $overdue_result = $stmt->get_result();
    $overdue_data = $overdue_result->fetch_assoc();
    $overdue_loans_count = $overdue_data['count'];
} catch (Exception $e) {
    error_log("Overdue loans error: " . $e->getMessage());
}

// Get user's loan history count
try {
    $loan_history_query = "SELECT COUNT(*) as count FROM lainat WHERE jasen_id = ?";
    $stmt = $conn->prepare($loan_history_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $loan_history_result = $stmt->get_result();
    $loan_history = $loan_history_result->fetch_assoc();
    $loan_history_count = $loan_history['count'];
} catch (Exception $e) {
    error_log("Loan history error: " . $e->getMessage());
}

// Get unpaid fines amount
try {
    $fines_query = "SELECT SUM(sakko_maara - IFNULL(maksettu_maara, 0)) as total FROM sakot WHERE jasen_id = ? AND tila IN ('maksettava', 'osittain')";
    $stmt = $conn->prepare($fines_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $fines_result = $stmt->get_result();
    $fines_data = $fines_result->fetch_assoc();
    if ($fines_data && $fines_data['total'] !== null) {
        $fines_total = $fines_data['total'];
    }
} catch (Exception $e) {
    error_log("Fines error: " . $e->getMessage());
}

// Get available devices count
try {
    $devices_query = "SELECT COUNT(*) as count FROM Laitteet WHERE tila = 'saatavilla'";
    $devices_result = $conn->query($devices_query);
    if ($devices_result) {
        $devices = $devices_result->fetch_assoc();
        $available_devices_count = $devices['count'];
    }
} catch (Exception $e) {
    error_log("Devices count error: " . $e->getMessage());
}

// Get user's active device loans count
try {
    $device_loans_query = "SELECT COUNT(*) as count FROM Laitelainat WHERE jasen_id = ? AND palautus_pvm IS NULL";
    $stmt = $conn->prepare($device_loans_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $device_loans_result = $stmt->get_result();
    $device_loans = $device_loans_result->fetch_assoc();
    $active_device_loans_count = $device_loans['count'];
} catch (Exception $e) {
    error_log("Device loans error: " . $e->getMessage());
}

// Get user's active reservations count
try {
    $reservations_query = "SELECT COUNT(*) as count FROM varaukset WHERE jasen_id = ? AND tila = 'odottaa'";
    $stmt = $conn->prepare($reservations_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $reservations_result = $stmt->get_result();
    $reservations = $reservations_result->fetch_assoc();
    $reservations_count = $reservations['count'];
} catch (Exception $e) {
    error_log("Reservations error: " . $e->getMessage());
}

// Get available books list
$books_result = null;
try {
    $books_query = "SELECT DISTINCT k.id, k.nimi, k.tekija,
                           (SELECT COUNT(*) FROM Kirjakopiot kp WHERE kp.kirja_id = k.id AND kp.tila = 'saatavilla') as saatavilla
                    FROM kirjat k
                    WHERE EXISTS (SELECT 1 FROM Kirjakopiot kp WHERE kp.kirja_id = k.id AND kp.tila = 'saatavilla')
                    ORDER BY RAND() LIMIT 4";
    $books_result = $conn->query($books_query);
} catch (Exception $e) {
    error_log("Books list error: " . $e->getMessage());
}

// Get available devices list
$available_devices_result = null;
try {
    $devices_list_query = "SELECT id, merkki, malli, tila, kunto
                          FROM Laitteet
                          WHERE tila = 'saatavilla'
                          ORDER BY RAND() LIMIT 4";
    $available_devices_result = $conn->query($devices_list_query);
} catch (Exception $e) {
    error_log("Devices list error: " . $e->getMessage());
}

// Get current active loans
$current_loans_result = null;
try {
    $current_loans_query = "SELECT l.*, k.nimi, k.tekija
                          FROM lainat l
                          JOIN kirjat k ON l.kirja_id = k.id
                          WHERE l.jasen_id = ? AND l.tila IN ('aktiivinen', 'myohassa')
                          ORDER BY l.erapaiva ASC";
    $stmt = $conn->prepare($current_loans_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $current_loans_result = $stmt->get_result();
} catch (Exception $e) {
    error_log("Current loans error: " . $e->getMessage());
}

// Get user's reservations
$reservations_result = null;
try {
    $reservations_query = "SELECT v.*, k.nimi, k.tekija
                          FROM varaukset v
                          JOIN kirjat k ON v.kirja_id = k.id
                          WHERE v.jasen_id = ? AND v.tila = 'odottaa'
                          ORDER BY v.varaus_paiva DESC";
    $stmt = $conn->prepare($reservations_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $reservations_result = $stmt->get_result();
} catch (Exception $e) {
    error_log("Reservations list error: " . $e->getMessage());
}

// Handle message sending
if ($_SERVER['REQUEST_METHOD'] == 'POST' && isset($_POST['send_message'])) {
    $message = $_POST['message'] ?? '';
    $recipient_id = $_POST['recipient_id'] ?? null;

    if ($message && $recipient_id) {
        $message_query = "INSERT INTO viestit (lahettaja_id, vastaanottaja_id, viesti) VALUES (?, ?, ?)";
        $stmt = $conn->prepare($message_query);
        $stmt->bind_param("iis", $user_id, $recipient_id, $message);

        if ($stmt->execute()) {
            $message_success = "Viesti lähetetty onnistuneesti!";
        } else {
            $message_error = "Viestin lähetys epäonnistui: " . $conn->error;
        }
    } else {
        $message_error = "Täytä viesti ja valitse vastaanottaja.";
    }
}

// Get profile image
$profile_image = null;
$stmt = $conn->prepare("SELECT profile_image FROM jasenet WHERE id = ?");
$stmt->bind_param("i", $user_id);
$stmt->execute();
$result = $stmt->get_result();
if ($row = $result->fetch_assoc()) {
    $profile_image = $row['profile_image'];
}
// Get user initials for avatar
$initials = strtoupper(substr($user['etunimi'], 0, 1) . substr($user['sukunimi'], 0, 1));

// Get staff members for messaging (both admin and manager)
$staff_members = [];
try {
    $staff_query = "SELECT id, etunimi, sukunimi, rooli FROM jasenet WHERE rooli IN ('admin', 'manager') AND id != ?";
    $stmt = $conn->prepare($staff_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $staff_result = $stmt->get_result();
    while ($staff = $staff_result->fetch_assoc()) {
        $staff_members[] = $staff;
    }
} catch (Exception $e) {
    error_log("Staff query error: " . $e->getMessage());
}

// Get unread messages count
$unread_messages_count = 0;
try {
    $unread_query = "SELECT COUNT(*) as count FROM viestit WHERE vastaanottaja_id = ? AND luettu = 0";
    $stmt = $conn->prepare($unread_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
    $unread_result = $stmt->get_result();
    $unread_data = $unread_result->fetch_assoc();
    $unread_messages_count = $unread_data['count'] ?? 0;
} catch (Exception $e) {
    error_log("Unread messages error: " . $e->getMessage());
}

// Get all messages
$all_messages = [];
try {
    $messages_query = "SELECT v.*,
                      l.etunimi as lahettaja_etunimi, l.sukunimi as lahettaja_sukunimi, l.rooli as lahettaja_rooli,
                      v2.etunimi as vastaanottaja_etunimi, v2.sukunimi as vastaanottaja_sukunimi, v2.rooli as vastaanottaja_rooli
                      FROM viestit v
                      LEFT JOIN jasenet l ON v.lahettaja_id = l.id
                      LEFT JOIN jasenet v2 ON v.vastaanottaja_id = v2.id
                      WHERE v.lahettaja_id = ? OR v.vastaanottaja_id = ?
                      ORDER BY v.luontiaika DESC";
    $stmt = $conn->prepare($messages_query);
    $stmt->bind_param("ii", $user_id, $user_id);
    $stmt->execute();
    $messages_result = $stmt->get_result();
    while ($message = $messages_result->fetch_assoc()) {
        $all_messages[] = $message;
    }

    // Mark messages as read
    $mark_read_query = "UPDATE viestit SET luettu = 1 WHERE vastaanottaja_id = ? AND luettu = 0";
    $stmt = $conn->prepare($mark_read_query);
    $stmt->bind_param("i", $user_id);
    $stmt->execute();
} catch (Exception $e) {
    error_log("Messages query error: " . $e->getMessage());
}
?>

<!DOCTYPE html>
<html lang="fi">
