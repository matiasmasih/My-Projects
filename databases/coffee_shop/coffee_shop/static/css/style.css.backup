/* MODERN COFFEE SHOP CSS - NO SHADOWS */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #FAF7F2;
    color: #1A1A1A;
    padding-top: 80px;
}

/* Navigation */
.navbar {
    background: white;
    border-bottom: 1px solid #E8E0D5;
    padding: 1rem 0;
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 1000;
}

.navbar-brand {
    font-size: 1.5rem;
    font-weight: 700;
    color: #C67C4E !important;
}

.navbar-brand i {
    color: #D4AF37;
    margin-right: 8px;
}

.nav-link {
    font-weight: 500;
    color: #333 !important;
    transition: 0.3s;
}

.nav-link:hover {
    color: #C67C4E !important;
}

/* Hero Section */
.hero {
    background: linear-gradient(135deg, rgba(0,0,0,0.6), rgba(0,0,0,0.4)), url('https://images.pexels.com/photos/312418/pexels-photo-312418.jpeg');
    background-size: cover;
    background-position: center;
    min-height: 80vh;
    display: flex;
    align-items: center;
}

.hero h1 {
    font-size: 3.5rem;
    font-weight: 800;
    color: white;
    margin-bottom: 20px;
}

.hero h1 span {
    color: #D4AF37;
}

.hero p {
    font-size: 1.2rem;
    color: rgba(255,255,255,0.9);
    margin-bottom: 30px;
}

/* Buttons */
.btn-primary {
    background: #C67C4E;
    border: none;
    padding: 12px 32px;
    border-radius: 50px;
    font-weight: 600;
    transition: 0.3s;
}

.btn-primary:hover {
    background: #A0522D;
    transform: translateY(-2px);
}

/* Product Cards - NO SHADOWS */
.product-card {
    background: white;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #E8E0D5;
    transition: all 0.3s ease;
    height: 100%;
}

.product-card:hover {
    border-color: #C67C4E;
    transform: translateY(-3px);
}

.product-image {
    height: 200px;
    overflow: hidden;
    background: #F5F0E8;
}

.product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
}

.product-card:hover .product-image img {
    transform: scale(1.03);
}

.product-info {
    padding: 18px;
}

.product-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 6px;
    color: #2C1810;
}

.product-desc {
    font-size: 0.8rem;
    color: #888;
    margin-bottom: 12px;
    line-height: 1.4;
}

.product-price {
    font-size: 1.3rem;
    font-weight: 700;
    color: #C67C4E;
}

.btn-add {
    background: #C67C4E;
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 25px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    transition: 0.3s;
}

.btn-add:hover {
    background: #A0522D;
}

/* Category Badges */
.category-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 15px;
    font-size: 0.65rem;
    font-weight: 600;
    margin-bottom: 8px;
}

.category-coffee { background: #C67C4E; color: white; }
.category-pastry { background: #D4AF37; color: #2C1810; }
.category-tea { background: #4A7C59; color: white; }
.category-beverage { background: #A0522D; color: white; }

/* Cart Badge */
.cart-count {
    background: #D4AF37;
    color: #1A1A1A;
    border-radius: 50%;
    padding: 2px 8px;
    font-size: 11px;
    margin-left: 5px;
}

/* Chatbot */
.chatbot-toggle {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 55px;
    height: 55px;
    border-radius: 50%;
    background: #C67C4E;
    border: none;
    color: white;
    font-size: 22px;
    cursor: pointer;
    z-index: 999;
    transition: 0.3s;
}

.chatbot-toggle:hover {
    transform: scale(1.05);
    background: #A0522D;
}

.chatbot-container {
    position: fixed;
    bottom: 95px;
    right: 24px;
    width: 340px;
    height: 460px;
    background: white;
    border-radius: 16px;
    display: none;
    flex-direction: column;
    overflow: hidden;
    z-index: 1000;
    border: 1px solid #E8E0D5;
}

.chatbot-container.active {
    display: flex;
}

.chatbot-header {
    background: #C67C4E;
    color: white;
    padding: 12px 15px;
}

.chatbot-messages {
    flex: 1;
    overflow-y: auto;
    padding: 15px;
    background: #F8F9FA;
}

.message {
    max-width: 80%;
    padding: 8px 12px;
    border-radius: 16px;
    margin-bottom: 8px;
    font-size: 0.85rem;
}

.message.user {
    background: #C67C4E;
    color: white;
    margin-left: auto;
}

.message.bot {
    background: white;
    color: #333;
    border: 1px solid #E0E0E0;
}

.chatbot-input {
    display: flex;
    gap: 8px;
    padding: 12px;
    border-top: 1px solid #E0E0E0;
    background: white;
}

.chatbot-input input {
    flex: 1;
    padding: 8px 12px;
    border: 1px solid #E0E0E0;
    border-radius: 25px;
    outline: none;
}

.chatbot-input button {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #C67C4E;
    border: none;
    color: white;
    cursor: pointer;
}

/* Footer */
.footer {
    background: #1A1A1A;
    color: white;
    padding: 50px 0 30px;
    margin-top: 60px;
}

.footer a {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: 0.3s;
}

.footer a:hover {
    color: #D4AF37;
}

.social-links {
    display: flex;
    gap: 12px;
}

.social-links a {
    width: 36px;
    height: 36px;
    background: rgba(255,255,255,0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: 0.3s;
}

.social-links a:hover {
    background: #D4AF37;
    color: #1A1A1A;
}

/* Responsive */
@media (max-width: 768px) {
    body {
        padding-top: 70px;
    }
    
    .hero h1 {
        font-size: 2rem;
    }
    
    .chatbot-container {
        width: 300px;
        right: 16px;
        bottom: 85px;
    }
}

/* Search Section */
.search-section {
    background: white;
    border-radius: 12px;
    padding: 20px;
    margin-bottom: 30px;
    border: 1px solid #E8E0D5;
}

.filter-btn {
    padding: 6px 16px;
    border-radius: 25px;
    background: #F5F0E8;
    border: none;
    color: #666;
    font-size: 0.8rem;
    cursor: pointer;
    transition: all 0.3s ease;
}

.filter-btn:hover, .filter-btn.active {
    background: #C67C4E;
    color: white;
}
.product-price {
    direction: ltr !important;
    unicode-bidi: embed !important;
    display: inline-block !important;
}

/* ========== DARK MODE STYLES ========== */
body.dark-mode {
    background: #121212;
    color: #E8E8E8;
}

body.dark-mode .navbar {
    background: #1E1E1E !important;
    border-bottom-color: #333;
}

body.dark-mode .navbar-brand {
    color: #C67C4E !important;
}

body.dark-mode .nav-link {
    color: #E8E8E8 !important;
}

body.dark-mode .nav-link:hover {
    color: #C67C4E !important;
}

/* Cards */
body.dark-mode .product-card,
body.dark-mode .order-card,
body.dark-mode .delivery-card,
body.dark-mode .search-section,
body.dark-mode .card,
body.dark-mode .stat-card,
body.dark-mode .profile-card {
    background: #1E1E1E;
    border-color: #333;
}

body.dark-mode .product-title,
body.dark-mode .category-title,
body.dark-mode .product-name,
body.dark-mode .checkout-header h1 {
    color: #E8E8E8;
}

body.dark-mode .product-desc,
body.dark-mode .text-muted,
body.dark-mode .card-text,
body.dark-mode .summary-line span {
    color: #AAAAAA !important;
}

/* Product price */
body.dark-mode .product-price {
    color: #C67C4E;
}

/* Buttons */
body.dark-mode .btn-add {
    background: #C67C4E;
}

body.dark-mode .btn-add:hover {
    background: #A0522D;
}

body.dark-mode .filter-btn {
    background: #2C2C2C;
    color: #AAAAAA;
}

body.dark-mode .filter-btn:hover,
body.dark-mode .filter-btn.active {
    background: #C67C4E;
    color: white;
}

/* Forms */
body.dark-mode .form-control,
body.dark-mode .form-select {
    background: #2C2C2C;
    border-color: #444;
    color: #E8E8E8;
}

body.dark-mode .form-control:focus,
body.dark-mode .form-select:focus {
    border-color: #C67C4E;
    background: #2C2C2C;
    color: #E8E8E8;
}

body.dark-mode .form-label {
    color: #E8E8E8;
}

body.dark-mode .info-box {
    background: #2C2C2C;
}

body.dark-mode .delivery-address,
body.dark-mode .bg-light {
    background: #2C2C2C !important;
}

/* Footer */
body.dark-mode .footer {
    background: #0D0D0D;
}

/* Chatbot */
body.dark-mode .chatbot-container {
    background: #1E1E1E;
    border-color: #333;
}

body.dark-mode .chatbot-messages {
    background: #1E1E1E;
}

body.dark-mode .message.bot {
    background: #2C2C2C;
    color: #E8E8E8;
    border-color: #444;
}

body.dark-mode .chatbot-input {
    background: #1E1E1E;
    border-top-color: #333;
}

body.dark-mode .chatbot-input input {
    background: #2C2C2C;
    border-color: #444;
    color: #E8E8E8;
}

/* Tables */
body.dark-mode .table {
    color: #E8E8E8;
}

body.dark-mode .table th,
body.dark-mode .table td {
    border-color: #333;
}

/* Alerts */
body.dark-mode .alert-info {
    background: #2C2C2C;
    border-color: #C67C4E;
    color: #E8E8E8;
}

/* Danger Zone */
body.dark-mode .danger-zone {
    background: #2C2C2C;
    border-color: #dc3545;
}

/* Referral Box */
body.dark-mode .referral-box {
    background: #2C2C2C;
}

body.dark-mode .referral-code {
    background: #1E1E1E;
    color: #C67C4E;
}

/* Stats Cards */
body.dark-mode .stat-card {
    background: #1E1E1E;
    border: 1px solid #333;
}

body.dark-mode .stat-number {
    color: #E8E8E8;
}

body.dark-mode .stat-label {
    color: #AAAAAA;
}

/* Dark Mode Toggle Button */
.dark-mode-toggle {
    background: none;
    border: none;
    font-size: 1.2rem;
    cursor: pointer;
    padding: 8px 12px;
    border-radius: 50%;
    transition: all 0.3s ease;
    color: inherit;
}

.dark-mode-toggle:hover {
    background: rgba(198,124,78,0.2);
    transform: scale(1.1);
}

/* Notification Bell & Dark Mode Toggle - Works in both Light and Dark Mode */
.notification-bell, .dark-mode-toggle {
    background: transparent;
    border: 1px solid #ddd;
    border-radius: 50%;
    width: 38px;
    height: 38px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-left: 8px;
}

.notification-bell i, .dark-mode-toggle i {
    font-size: 18px;
    color: #333;
}

.notification-bell:hover, .dark-mode-toggle:hover {
    background: rgba(0,0,0,0.05);
    transform: scale(1.05);
    border-color: #C67C4E;
}

/* Dark Mode Styles */
body.dark-mode .notification-bell,
body.dark-mode .dark-mode-toggle {
    border: 1px solid rgba(255,255,255,0.3);
}

body.dark-mode .notification-bell i,
body.dark-mode .dark-mode-toggle i {
    color: white;
}

body.dark-mode .notification-bell:hover,
body.dark-mode .dark-mode-toggle:hover {
    background: rgba(255,255,255,0.1);
    border-color: #C67C4E;
}

/* Navbar - Keep all items in one row on desktop */
@media (min-width: 992px) {
    .navbar-nav {
        flex-direction: row;
        align-items: center;
        flex-wrap: nowrap;
    }
    
    .navbar-nav .nav-item {
        white-space: nowrap;
    }
    
    .navbar-nav .nav-link {
        padding: 0.5rem 0.75rem;
        font-size: 0.9rem;
    }
}

/* For very large screens, allow more padding */
@media (min-width: 1400px) {
    .navbar-nav .nav-link {
        padding: 0.5rem 1rem;
        font-size: 1rem;
    }
}
