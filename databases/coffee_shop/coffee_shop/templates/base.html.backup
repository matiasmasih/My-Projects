<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bean & Brew Coffee</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/style.css') }}">
    
    <!-- RTL Styles for Persian Language -->
    {% if session.lang == 'fa' %}
    <style>
        body { direction: rtl; text-align: right; font-family: 'Poppins', 'Tahoma', sans-serif; }
        .navbar-nav { margin-right: auto; margin-left: 0 !important; }
        .dropdown-menu { text-align: right; left: auto !important; right: 0 !important; }
        .me-auto { margin-right: auto !important; margin-left: 0 !important; }
        .ms-auto { margin-left: auto !important; margin-right: 0 !important; }
        .text-start { text-align: right !important; }
        .text-end { text-align: left !important; }
        /* Logo on right corner for RTL */
        .navbar-brand { margin-right: 0; margin-left: auto; }
    </style>
    {% else %}
    <style>
        /* Logo on left corner for LTR languages */
        .navbar-brand { margin-right: auto; }
    </style>
    {% endif %}
    
    <style>
        /* General Styles */
        .notification-bell {
            background: none;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            width: 38px;
            height: 38px;
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: 8px;
        }
        .notification-bell:hover {
            background: rgba(255,255,255,0.1);
            transform: scale(1.05);
            border-color: #C67C4E;
        }
        .notification-bell i {
            font-size: 18px;
        }
        .dark-mode-toggle {
            background: none;
            border: 1px solid rgba(255,255,255,0.3);
            border-radius: 50%;
            width: 38px;
            height: 38px;
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-left: 8px;
        }
        .dark-mode-toggle:hover {
            background: rgba(255,255,255,0.1);
            transform: scale(1.05);
            border-color: #C67C4E;
        }
        .cart-count {
            background: #C67C4E;
            border-radius: 50%;
            display: inline-block;
            font-size: 0.7rem;
            padding: 2px 6px;
            margin-left: 5px;
            color: white;
        }
        
        /* Dropdown visibility fix - ensure all items show */
        .dropdown-menu {
            max-height: 80vh;
            overflow-y: auto;
            z-index: 1050;
            min-width: 220px;
        }
        .dropdown-menu-end {
            right: 0;
            left: auto !important;
        }
        
        /* Navbar items */
        .navbar-nav {
            align-items: center;
            flex-wrap: wrap;
        }
        
        /* Footer */
        .footer {
            background: linear-gradient(135deg, #2C1810, #3D2518);
            color: white;
            padding: 50px 0 20px;
            margin-top: 60px;
        }
        .footer a {
            color: #C67C4E;
            text-decoration: none;
        }
        .footer a:hover {
            color: #D4AF37;
        }
        .social-links a {
            display: inline-block;
            width: 35px;
            height: 35px;
            background: rgba(255,255,255,0.1);
            border-radius: 50%;
            text-align: center;
            line-height: 35px;
            margin-right: 10px;
            transition: all 0.3s ease;
        }
        .social-links a:hover {
            background: #C67C4E;
            transform: translateY(-3px);
        }
        
        /* Chatbot Widget */
        #chatbot-widget {
            position: fixed;
            bottom: 20px;
            right: 20px;
            z-index: 1000;
        }
        .chatbot-toggle {
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: linear-gradient(135deg, #C67C4E, #A0522D);
            border: none;
            color: white;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            transition: all 0.3s ease;
        }
        .chatbot-toggle:hover {
            transform: scale(1.05);
        }
        .chatbot-container {
            display: none;
            position: absolute;
            bottom: 80px;
            right: 0;
            width: 350px;
            height: 450px;
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            overflow: hidden;
            flex-direction: column;
        }
        .chatbot-container.show {
            display: flex;
        }
        .chatbot-header {
            background: linear-gradient(135deg, #C67C4E, #A0522D);
            color: white;
            padding: 15px;
            display: flex;
            align-items: center;
        }
        .chatbot-messages {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            background: #f8f9fa;
        }
        .message {
            margin-bottom: 10px;
            padding: 8px 12px;
            border-radius: 18px;
            max-width: 80%;
        }
        .message.bot {
            background: white;
            color: #2C1810;
            border: 1px solid #E8E0D5;
        }
        .message.user {
            background: #C67C4E;
            color: white;
            margin-left: auto;
        }
        .chatbot-input {
            display: flex;
            padding: 10px;
            border-top: 1px solid #eee;
            background: white;
        }
        .chatbot-input input {
            flex: 1;
            padding: 8px 12px;
            border: 1px solid #ddd;
            border-radius: 20px;
            outline: none;
        }
        .chatbot-input button {
            background: #C67C4E;
            border: none;
            color: white;
            width: 35px;
            height: 35px;
            border-radius: 50%;
            margin-left: 8px;
            cursor: pointer;
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .chatbot-container {
                width: 300px;
                height: 400px;
                right: 0;
            }
            .navbar-nav .dropdown-menu {
                position: absolute !important;
            }
            .username-text, .admin-text, .lang-code {
                display: none;
            }
        }
    </style>
    
    <script>
        function enableNotifications() {
            if ("Notification" in window) {
                Notification.requestPermission().then(function(permission) {
                    if (permission === "granted") {
                        alert("Notifications enabled! You will receive order updates.");
                    } else {
                        alert("Notifications blocked. Please check your browser settings.");
                    }
                });
            } else {
                alert("Your browser does not support notifications.");
            }
        }

        function toggleDarkMode() {
            document.body.classList.toggle("dark-mode");
            const isDark = document.body.classList.contains("dark-mode");
            localStorage.setItem("darkMode", isDark);
            const icon = document.querySelector(".dark-mode-toggle i");
            if (icon) {
                icon.className = isDark ? "fas fa-sun" : "fas fa-moon";
            }
        }

        if (localStorage.getItem("darkMode") === "true") {
            document.body.classList.add("dark-mode");
            const icon = document.querySelector(".dark-mode-toggle i");
            if (icon) icon.className = "fas fa-sun";
        }

        if ("Notification" in window) {
            Notification.requestPermission();
        }
    </script>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark fixed-top">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">
            <i class="fas fa-mug-hot"></i> Bean & Brew Coffee
        </a>
        
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav mx-auto">
                <li class="nav-item"><a class="nav-link" href="/">{{ t('home') }}</a></li>
                <li class="nav-item"><a class="nav-link" href="/menu">{{ t('menu') }}</a></li>
                <li class="nav-item"><a class="nav-link" href="/favorites">{{ t('favorites') }}</a></li>
                <li class="nav-item"><a class="nav-link" href="/reviews">{{ t('reviews') }}</a></li>
                <li class="nav-item"><a class="nav-link" href="/newsletter">{{ t('newsletter_title') }}</a></li>
                <li class="nav-item"><a class="nav-link" href="/wifi">{{ t('wifi') }}</a></li>
            </ul>
            
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" href="/cart">
                        <i class="fas fa-shopping-cart"></i>
                        <span class="cart-count">0</span>
                    </a>
                </li>

                <li class="nav-item">
                    <button class="dark-mode-toggle" onclick="toggleDarkMode()">
                        <i class="fas fa-moon"></i>
                    </button>
                </li>

                <li class="nav-item">
                    <button class="notification-bell" onclick="enableNotifications()">
                        <i class="fas fa-bell"></i>
                    </button>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                        <i class="fas fa-globe"></i>
                        {% if session.lang == 'fi' %}FI
                        {% elif session.lang == 'sv' %}SV
                        {% elif session.lang == 'fa' %}FA
                        {% else %}EN{% endif %}
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="/set-lang/en">🇬🇧 English</a></li>
                        <li><a class="dropdown-item" href="/set-lang/fi">🇫🇮 Suomi</a></li>
                        <li><a class="dropdown-item" href="/set-lang/sv">🇸🇪 Svenska</a></li>
                        <li><a class="dropdown-item" href="/set-lang/fa">🇮🇷 فارسی</a></li>
                    </ul>
                </li>

                {% if current_user.is_authenticated %}
                    {% if current_user.is_admin %}
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-cog"></i> Admin
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><a class="dropdown-item" href="/admin/sales-dashboard"><i class="fas fa-chart-line me-2"></i>Dashboard</a></li>
                            <li><a class="dropdown-item" href="/admin/inventory"><i class="fas fa-boxes me-2"></i>Inventory</a></li>
                            <li><a class="dropdown-item" href="/admin/customers"><i class="fas fa-users me-2"></i>Customers</a></li>
                            <li><a class="dropdown-item" href="/admin/export"><i class="fas fa-download me-2"></i>Export</a></li>
                            <li><a class="dropdown-item" href="/admin/newsletter"><i class="fas fa-newspaper me-2"></i>Newsletter</a></li>
                        </ul>
                    </li>
                    {% endif %}
                    
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                            <i class="fas fa-user"></i> {{ current_user.username }}
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            {% if current_user.role == 'employee' %}
                            <li><a class="dropdown-item" href="/employee-dashboard"><i class="fas fa-user-tie me-2"></i>{{ t('employee_dashboard') }}</a></li>
                            {% endif %}
                            <li><a class="dropdown-item" href="/profile"><i class="fas fa-id-card me-2"></i>{{ t('profile') }}</a></li>
                            <li><a class="dropdown-item" href="/order-history"><i class="fas fa-box me-2"></i>{{ t('orders') }}</a></li>
                            <li><a class="dropdown-item" href="/track-order"><i class="fas fa-map-marker-alt me-2"></i>{{ t('track_order') }}</a></li>
                            <li><a class="dropdown-item" href="/chatbot-orders"><i class="fas fa-robot me-2"></i>{{ t('chatbot_orders_title') }}</a></li>
                            <li><a class="dropdown-item" href="/my-receipts"><i class="fas fa-receipt me-2"></i>{{ t('my_receipts') }}</a></li>
                            <li><a class="dropdown-item" href="/loyalty"><i class="fas fa-gift me-2"></i>{{ t('loyalty_rewards') }}</a></li>
                            <li><a class="dropdown-item" href="/referral"><i class="fas fa-share-alt me-2"></i>{{ t('refer_friend') }}</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/cart"><i class="fas fa-shopping-cart me-2"></i>{{ t('cart') }}</a></li>
                            <li><a class="dropdown-item" href="/checkout"><i class="fas fa-credit-card me-2"></i>{{ t('checkout') }}</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="/logout"><i class="fas fa-sign-out-alt me-2"></i>{{ t('logout') }}</a></li>
                        </ul>
                    </li>
                {% else %}
                    <li class="nav-item"><a class="nav-link" href="/login">{{ t('login') }}</a></li>
                    <li class="nav-item"><a class="nav-link" href="/register">{{ t('register') }}</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-3">
    {% with messages = get_flashed_messages(with_categories=true) %}
        {% for category, message in messages %}
            <div class="alert alert-{{ category }} alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
    {% endwith %}
</div>

{% block content %}{% endblock %}

<footer class="footer">
    <div class="container">
        <div class="row">
            <div class="col-md-4 mb-4">
                <h5><i class="fas fa-mug-hot me-2"></i>Bean & Brew Coffee</h5>
                <p>{% if session.lang == 'fi' %}Käsintehtyä kahvia vuodesta 2026{% elif session.lang == 'sv' %}Hantverkskaffe sedan 2026{% elif session.lang == 'fa' %}قهوه دست ساز از سال ۲۰۲۶{% else %}Handcrafted coffee since 2026{% endif %}</p>
                <div class="social-links mt-3">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-twitter"></i></a>
                    <a href="#"><i class="fab fa-tiktok"></i></a>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <h5><i class="fas fa-clock me-2"></i>{% if session.lang == 'fi' %}Aukioloajat{% elif session.lang == 'sv' %}Öppettider{% elif session.lang == 'fa' %}ساعات کاری{% else %}Opening Hours{% endif %}</h5>
                <p class="mb-1">{% if session.lang == 'fi' %}Ma-Pe: 7-21{% elif session.lang == 'sv' %}Mån-Fre: 7-21{% elif session.lang == 'fa' %}دوشنبه تا جمعه: ۷ صبح تا ۹ شب{% else %}Mon-Fri: 7AM - 9PM{% endif %}</p>
                <p class="mb-1">{% if session.lang == 'fi' %}La-Su: 8-22{% elif session.lang == 'sv' %}Lör-Sön: 8-22{% elif session.lang == 'fa' %}شنبه و یکشنبه: ۸ صبح تا ۱۰ شب{% else %}Sat-Sun: 8AM - 10PM{% endif %}</p>
                <p class="mt-2"><i class="fas fa-wifi me-2"></i>{% if session.lang == 'fi' %}WiFi{% elif session.lang == 'sv' %}Gratis WiFi{% elif session.lang == 'fa' %}وای فای رایگان{% else %}Free WiFi{% endif %}</p>
            </div>
            <div class="col-md-4 mb-4">
                <h5><i class="fas fa-map-marker-alt me-2"></i>{% if session.lang == 'fi' %}Ota yhteyttä{% elif session.lang == 'sv' %}Kontakta oss{% elif session.lang == 'fa' %}تماس با ما{% else %}Contact Us{% endif %}</h5>
                <p class="mb-1"><i class="fas fa-location-dot me-2"></i>Iskoskuja 3 C 111, Vantaa</p>
                <p class="mb-1"><i class="fas fa-phone me-2"></i>+(358) 413114312</p>
                <p class="mb-1"><i class="fas fa-envelope me-2"></i>matiasmasih@gmail.com</p>
            </div>
        </div>
        <div class="text-center pt-4 mt-3 border-top border-secondary">
            <p class="mb-0">&copy; 2026 Bean & Brew Coffee. All rights reserved.</p>
        </div>
    </div>
</footer>

<div id="chatbot-widget">
    <button class="chatbot-toggle" id="chatbotToggle">
        <i class="fas fa-robot"></i>
    </button>
    <div class="chatbot-container" id="chatbotContainer">
        <div class="chatbot-header">
            <i class="fas fa-coffee"></i>
            <h6 class="mb-0 ms-2">Barista Assistant</h6>
            <button class="close-chat ms-auto" style="background: none; border: none; color: white; font-size: 20px; cursor: pointer;">&times;</button>
        </div>
        <div class="chatbot-messages" id="chatMessages">
            <div class="message bot">
                Hello! I'm your barista assistant. Ask me about our menu, hours, or get a drink recommendation! ☕
            </div>
        </div>
        <div class="chatbot-input">
            <input type="text" id="userMessage" placeholder="Ask me anything...">
            <button id="sendMessage"><i class="fas fa-paper-plane"></i></button>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="{{ url_for('static', filename='js/chatbot.js') }}"></script>
<script src="{{ url_for('static', filename='js/main.js') }}"></script>
<script src="{{ url_for('static', filename='js/cart.js') }}"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    fetch('/api/cart/count')
        .then(r => r.json())
        .then(data => {
            const cartCount = document.querySelector('.cart-count');
            if (cartCount) cartCount.textContent = data.count;
        });
});
</script>
</body>
</html>
